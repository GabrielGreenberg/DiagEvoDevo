{
  "name": "diagram-evolver",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Evolve random line segments into faithful diagrams under a principled homomorphism score.",
  "keywords": [
    "diagram",
    "data-visualization",
    "homomorphism",
    "optimization",
    "autograd",
    "gradient-descent",
    "bar-chart",
    "evolutionary-computation",
    "graphical-perception",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GabrielGreenberg/DiagEvoDevo.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"scripts/**/*.ts\"",
    "check": "npm run typecheck && npm run lint && npm run test",
    "bench": "vite-node scripts/bench.ts",
    "accept": "vite-node scripts/accept.ts",
    "gradcheck": "vitest run -t gradcheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vite": "^6.0.5",
    "vite-node": "^3.0.0",
    "vitest": "^3.0.0"
  }
}
